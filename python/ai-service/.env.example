# AI Service Configuration

# AI Provider Selection
# Options: claude, openai, ollama
AI_PROVIDER_STORY=claude          # For story missions, critical narrative
AI_PROVIDER_QUICK=ollama          # For quick content (ship docs, UI text)
AI_PROVIDER_RANDOM=openai         # For random encounters, minor missions

# API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Ollama Configuration (local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Model Selection
CLAUDE_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-3.5-turbo

# Redis Cache Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# AI Generation Settings
TEMPERATURE=0.8
MAX_TOKENS=1500
TOP_P=1.0

# Server Configuration
HOST=0.0.0.0
PORT=8001
WORKERS=1
LOG_LEVEL=info

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=2

# Rate Limiting (tokens per minute)
RATE_LIMIT_TPM=10000
