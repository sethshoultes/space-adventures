# AI Service Configuration
# NCC-1701-1 Registry

# AI Provider Selection
# Options: claude, openai, ollama
AI_PROVIDER_STORY=claude          # For story missions, critical narrative
AI_PROVIDER_QUICK=ollama          # For quick content (ship docs, UI text)
AI_PROVIDER_RANDOM=openai         # For random encounters, minor missions

# API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Ollama Configuration (local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Orchestrator Configuration (AI Agent Models)
# All agents default to Ollama for local, API-key-free operation
OLLAMA_MODEL_ATLAS=llama3.2:latest
OLLAMA_MODEL_COMPANION=llama3.2:latest
OLLAMA_MODEL_STORYTELLER=llama3.2:latest
OLLAMA_MODEL_TACTICAL=llama3.2:latest

# Provider Selection per Agent
# Options: ollama (local/free), openai (requires API key), anthropic (requires API key)
PROVIDER_ATLAS=ollama
PROVIDER_STORYTELLER=ollama
PROVIDER_TACTICAL=ollama
PROVIDER_COMPANION=ollama

# Temperature Settings per Agent
TEMPERATURE_ATLAS=0.7
TEMPERATURE_STORYTELLER=0.9
TEMPERATURE_TACTICAL=0.6
TEMPERATURE_COMPANION=0.8

# Model Selection (for cloud providers)
CLAUDE_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-3.5-turbo

# Redis Cache Configuration (NCC-1701-4)
REDIS_HOST=redis
REDIS_PORT=17014
REDIS_DB=0
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# AI Generation Settings
TEMPERATURE=0.8
MAX_TOKENS=1500
TOP_P=1.0

# Server Configuration
HOST=0.0.0.0
PORT=17011
WORKERS=1
LOG_LEVEL=info

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=2

# Rate Limiting (tokens per minute)
RATE_LIMIT_TPM=10000

# ========================================
# AI-FIRST BACKGROUND TASKS
# ========================================

# Background Task System
BACKGROUND_TASKS_ENABLED=true         # Enable/disable all background tasks
STARTUP_PREGENERATE=true              # Pre-generate missions on startup

# Mission Queue Configuration
MISSION_QUEUE_ENABLED=true            # Enable mission pre-generation queue
MISSION_QUEUE_SIZE=10                 # Max missions per queue (type/difficulty)
MISSION_TTL_HOURS=24                  # How long missions stay in queue

# Task Schedule Configuration
# Mission replenishment runs every 30 minutes
# Daily events generate at 3 AM
# Cache cleanup runs at 2 AM daily
# Galaxy refresh runs Mondays at 2 AM

# Optional: Override schedule intervals (minutes)
# MISSION_REPLENISH_INTERVAL=30
# CACHE_CLEANUP_HOUR=2
# DAILY_EVENTS_HOUR=3
