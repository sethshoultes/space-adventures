# AI Orchestrator Prototype - Environment Configuration

# =============================================================================
# AI PROVIDER API KEYS
# =============================================================================

# Anthropic (Claude) - Required for Storyteller agent
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI - Required for Tactical agent
OPENAI_API_KEY=sk-your-api-key-here

# =============================================================================
# OLLAMA CONFIGURATION (Local/Free)
# =============================================================================

# Ollama base URL (running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Models to use (must be pulled first: ollama pull llama3.2:3b)
OLLAMA_MODEL_ATLAS=llama3.2:3b
OLLAMA_MODEL_COMPANION=llama3.2:3b

# =============================================================================
# LITELLM CONFIGURATION
# =============================================================================

# Enable debug logging for LiteLLM
LITELLM_LOG=DEBUG

# =============================================================================
# PROVIDER SELECTION
# =============================================================================

# Which provider to use for each agent
# Options: ollama, anthropic, openai
PROVIDER_ATLAS=ollama
PROVIDER_STORYTELLER=anthropic
PROVIDER_TACTICAL=openai
PROVIDER_COMPANION=ollama

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Temperature for each agent (0.0-1.0)
TEMPERATURE_ATLAS=0.7
TEMPERATURE_STORYTELLER=0.9
TEMPERATURE_TACTICAL=0.6
TEMPERATURE_COMPANION=0.8

# Max tokens per response
MAX_TOKENS=2000

# =============================================================================
# FASTAPI SERVER
# =============================================================================

# Server host and port
API_HOST=0.0.0.0
API_PORT=8003

# Enable CORS
ENABLE_CORS=true
