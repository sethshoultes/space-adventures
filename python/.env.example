# Space Adventures - AI Service Configuration
# Copy this file to .env and fill in your values

# AI Provider: Choose "openai" or "ollama"
AI_PROVIDER=ollama

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
# Alternative cheaper model: gpt-3.5-turbo

# Ollama Configuration (if using Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
# Other good models: mistral, codellama, mixtral

# Generation Settings
TEMPERATURE=0.8
# Temperature: 0.0 (deterministic) to 1.0 (creative)
# Recommended: 0.6-0.8 for game content

MAX_TOKENS=1500
# Maximum length of AI responses
# Higher = longer but more expensive (OpenAI)

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
# Cache responses for 24 hours (86400 seconds)

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
# Set DEBUG=false in production

# CORS (if needed for web version)
CORS_ORIGINS=*
# In production, set to specific origins: http://localhost:3000

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
