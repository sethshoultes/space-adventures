# Space Adventures - Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# PORT CONFIGURATION - NCC-1701 Registry System
# ==============================================================================
# Based on USS Enterprise NCC-1701
# See docs/PORT-MAPPING.md for complete reference

# Gateway Service (NCC-1701-0)
GATEWAY_PORT=17010

# AI Service (NCC-1701-1)
AI_SERVICE_PORT=17011

# Whisper Service (NCC-1701-2)
WHISPER_SERVICE_PORT=17012

# Image Service (NCC-1701-3) - Future
IMAGE_SERVICE_PORT=17013

# Redis (NCC-1701-4)
REDIS_PORT=17014

# PostgreSQL (NCC-1701-5) - Future
POSTGRES_PORT=17015

# ==============================================================================
# AI PROVIDERS
# ==============================================================================

# Provider Selection for Different Tasks
# Options: claude, openai, ollama
AI_PROVIDER_STORY=ollama          # Story missions, critical narrative
AI_PROVIDER_QUICK=ollama          # Quick content (ship docs, UI text)
AI_PROVIDER_RANDOM=ollama         # Random encounters, minor missions

# ==============================================================================
# API KEYS
# ==============================================================================

# Anthropic Claude (Optional - for high-quality story content)
# Get key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (Optional - for GPT-3.5/4)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ==============================================================================
# OLLAMA (Local, Free AI)
# ==============================================================================

# Ollama Base URL (local installation)
# Install from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model (recommended: llama3.2:3b)
# Pull with: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# ==============================================================================
# AI MODELS
# ==============================================================================

# Claude Model (if using Anthropic)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI Model (if using OpenAI)
OPENAI_MODEL=gpt-3.5-turbo

# ==============================================================================
# WHISPER (Voice Transcription)
# ==============================================================================

# Whisper Model Selection
# Options: tiny, base (recommended), small, medium, large
WHISPER_MODEL=base

# Device for Whisper
# Options: cpu, cuda (GPU significantly faster but optional)
DEVICE=cpu

# ==============================================================================
# CACHE SETTINGS
# ==============================================================================

CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# ==============================================================================
# AI GENERATION SETTINGS
# ==============================================================================

TEMPERATURE=0.8
MAX_TOKENS=1500

# ==============================================================================
# DEVELOPMENT SETTINGS
# ==============================================================================

# Log Level: debug, info, warning, error
LOG_LEVEL=info

# Enable debug tools (Redis Commander, etc.)
# Start with: docker-compose --profile debug up
ENABLE_DEBUG_TOOLS=false
