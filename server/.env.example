# Space Adventures Server Configuration
# Copy this file to .env and fill in your values.
# All variables are prefixed with SA_ to avoid collisions.

# Required for AI Game Master (get key at https://console.anthropic.com/)
SA_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude model (default: claude-sonnet-4-20250514)
# SA_CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Enable debug logging
# SA_DEBUG=true

# Optional: Server port (default: 8000)
# SA_PORT=8000

# Optional: CORS origins (default: localhost:3000, localhost:5173)
# SA_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Optional: Redis URL (for future event queue)
# SA_REDIS_URL=redis://localhost:6379

# Optional: Database file path (default: server/space_adventures.db)
# SA_DATABASE_PATH=./space_adventures.db

# Optional: Memory directory (default: project_root/memory/)
# SA_MEMORY_DIR=./memory
